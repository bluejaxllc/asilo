generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Facility / Retirement Home (tenant)
model Facility {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("FREE") // FREE, CORE, ENTERPRISE

  users         User[]
  patients      Patient[]
  tasks         Task[]
  medications   Medication[]
  notifications Notification[]
  settings      FacilitySetting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// User model for Staff and Admins
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  role          String    @default("STAFF") // ADMIN, DOCTOR, NURSE, KITCHEN, FAMILY
  password      String?
  image         String?

  // Facility link (tenant)
  facilityId String?
  facility   Facility? @relation(fields: [facilityId], references: [id])
  
  // OAuth adapter relations
  accounts   Account[]
  sessions   Session[]

  attendance Attendance[]
  assignedTasks Task[]
  logs       DailyLog[]
  sentMessages FamilyMessage[] @relation("SentMessages")

  // Relation to Patient (for Family Members)
  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// OAuth Account (required by @auth/prisma-adapter)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Session (required by @auth/prisma-adapter)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Verification Token (required by @auth/prisma-adapter)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Pending Registration (holds signup data until email verified)
model PendingRegistration {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  hashedPassword String
  role           String   @default("ADMIN")
  facilityName   String?
  plan           String?
  createdAt      DateTime @default(now())
}

// Patient / Resident
model Patient {
  id        String   @id @default(cuid())
  name      String
  room      String?
  status    String   @default("Estable") // Estable, Delicado, Hospitalizado
  age       Int?
  dateOfBirth DateTime?
  medicalHistory String?
  dietaryNeeds   String?

  // Facility link (tenant)
  facilityId String?
  facility   Facility? @relation(fields: [facilityId], references: [id])
  
  logs      DailyLog[]
  medications PatientMedication[]
  tasks     Task[]
  notifications Notification[]
  
  // Family Members linked to this patient
  familyMembers User[]
  familyMessages FamilyMessage[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tasks for Staff
model Task {
  id        String   @id @default(cuid())
  title     String
  description String?
  priority  String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  status    String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  dueDate   DateTime?
  
  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id])
  
  patientId   String?
  patient     Patient? @relation(fields: [patientId], references: [id])

  // Facility link (tenant)
  facilityId String?
  facility   Facility? @relation(fields: [facilityId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Daily Logs (Bitácora)
model DailyLog {
  id        String   @id @default(cuid())
  type      String   // VITALS, FOOD, HYGIENE, INCIDENT
  notes     String?
  value     String?  // e.g., "120/80" for BP, "All ate" for Food
  
  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id])
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  
  createdAt DateTime @default(now())
}

// Inventory & Medications
model Medication {
  id        String   @id @default(cuid())
  name      String
  stock     Int
  unit      String   // pills, ml, boxes
  minStock  Int      @default(10)
  expiryDate DateTime?

  // Facility link (tenant)
  facilityId String?
  facility   Facility? @relation(fields: [facilityId], references: [id])
  
  patients  PatientMedication[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Junction table for Patient <-> Medication
model PatientMedication {
  id           String     @id @default(cuid())
  patientId    String
  patient      Patient    @relation(fields: [patientId], references: [id])
  
  medicationId String
  medication   Medication @relation(fields: [medicationId], references: [id])
  
  dosage       String     // e.g., "1 tablet every 8 hours"
  schedule     String?    // JSON or simple string text
  
  createdAt    DateTime   @default(now())
}

// Staff Attendance
model Attendance {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  checkIn   DateTime @default(now())
  checkOut  DateTime?
  
  createdAt DateTime @default(now())
}

// Notifications (Admin Alerts)
model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   // INFO, WARNING, CRITICAL
  read      Boolean  @default(false)
  
  recipientRole String?  // Target role: ADMIN, STAFF, DOCTOR, NURSE, KITCHEN, FAMILY, or null for ALL
  recipientName String?  // Optional specific person name
  
  patientId     String?
  patient       Patient? @relation(fields: [patientId], references: [id])

  // Facility link (tenant)
  facilityId String?
  facility   Facility? @relation(fields: [facilityId], references: [id])

  createdAt DateTime @default(now())
}

// Facility Settings (Key-Value Store per facility)
model FacilitySetting {
  id    String @id @default(cuid())
  key   String
  value String

  facilityId String?
  facility   Facility? @relation(fields: [facilityId], references: [id])
  
  updatedAt DateTime @updatedAt

  @@unique([facilityId, key])
}

// Family Messages (Family <-> Staff communication about a patient)
model FamilyMessage {
  id          String   @id @default(cuid())
  content     String
  isFromFamily Boolean @default(true)
  
  fromUserId  String
  fromUser    User     @relation("SentMessages", fields: [fromUserId], references: [id])
  
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  
  createdAt   DateTime @default(now())
}
